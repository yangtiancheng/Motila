generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  USER
}

enum EmailProvider {
  QQ
  NETEASE_163
  CUSTOM
}

enum AuditAction {
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  USER_ROLE_CHANGE
  USER_PASSWORD_RESET
}

enum AuditEntity {
  USER
}

enum ModuleLifecycleStatus {
  NOT_INSTALLED
  INSTALLED
  ENABLED
  DISABLED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  DONE
  ARCHIVED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum RiskConfigVersionStatus {
  DRAFT
  PUBLISHED
  ROLLED_BACK
}

model User {
  id            String          @id @default(cuid())
  username      String          @unique
  email         String          @unique
  name          String
  avatarUrl     String?
  avatarImage   String?
  passwordHash  String
  role          UserRole        @default(USER)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  roles         UserRoleMap[]
  emailConfig   UserEmailConfig?
  emailSendLogs EmailSendLog[]
  emailInboxes  EmailInbox[]
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  entity      AuditEntity
  targetId    String
  targetName  String
  targetEmail String
  actorId     String
  actorEmail  String
  actorRole   UserRole
  detail      String?
  createdAt   DateTime    @default(now())
}

model FeatureModule {
  code         String                @id
  name         String
  description  String?
  status       ModuleLifecycleStatus @default(DISABLED)
  isCore       Boolean               @default(false)
  sortOrder    Int                   @default(100)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  dependencies ModuleDependency[]    @relation("ModuleDependencies")
  dependents   ModuleDependency[]    @relation("ModuleDependents")
}

model ModuleDependency {
  id            String        @id @default(cuid())
  moduleCode    String
  dependsOnCode String
  module        FeatureModule @relation("ModuleDependencies", fields: [moduleCode], references: [code], onDelete: Cascade)
  dependsOn     FeatureModule @relation("ModuleDependents", fields: [dependsOnCode], references: [code], onDelete: Cascade)

  @@unique([moduleCode, dependsOnCode])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Employee {
  id         String         @id @default(cuid())
  name       String
  email      String         @unique
  phone      String?
  department String?
  title      String?
  status     EmployeeStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Role {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  description String?
  isSystem    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  permissions RolePermission[]
  userRoles   UserRoleMap[]
  grants      RoleModuleGrant[]
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  moduleCode  String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRoleMap {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RoleModuleGrant {
  id         String   @id @default(cuid())
  roleId     String
  moduleCode String
  createdAt  DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleCode])
}

model UserEmailConfig {
  id              String        @id @default(cuid())
  userId          String        @unique
  provider        EmailProvider @default(CUSTOM)
  emailAddress    String
  authType        String        @default("authorization_code")
  secretEncrypted String
  smtpHost        String
  smtpPort        Int
  smtpSecure      Boolean       @default(true)
  imapHost        String
  imapPort        Int
  imapSecure      Boolean       @default(true)
  popHost         String?
  popPort         Int?
  popSecure       Boolean?
  enabled         Boolean       @default(true)
  lastTestAt      DateTime?
  lastTestStatus  String?
  lastTestMessage String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailSendLog {
  id         String   @id @default(cuid())
  userId     String
  to         String
  subject    String
  content    String
  status     String   @default("SUCCESS")
  error      String?
  sentAt     DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailInbox {
  id          String   @id @default(cuid())
  userId      String
  messageId   String
  folder      String   @default("INBOX")
  fromAddress String?
  toAddress   String?
  subject     String?
  textBody    String?
  htmlBody    String?
  receivedAt  DateTime?
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
}

model SystemConfig {
  id         String   @id @default(cuid())
  name       String
  title      String
  logoUrl    String?
  logoImage  String?
  footerText String?
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RiskControlConfig {
  id         String   @id @default(cuid())
  enabled    Boolean  @default(true)
  version    Int      @default(1)
  contentJson String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RiskControlConfigVersion {
  id          String                  @id @default(cuid())
  version     Int                     @unique
  status      RiskConfigVersionStatus @default(DRAFT)
  contentJson String
  comment     String?
  createdBy   String?
  publishedBy String?
  rolledBackFromVersion Int?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  publishedAt DateTime?
}
